generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// MODELS
//////////////////////////////////////////////////////

model User {
  id          String   @id @db.Char(24)
  name        String
  email       String   @unique
  password    String
  role        String   @default("user") // "admin" | "user"
  status      String   @default("active") // "active" | "inactive" | "locked"
  accessToken String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  createdProjects   Project[]           @relation("UserProjects")
  memberships       ProjectMembership[]
  stagesCreated     Stage[]             @relation("StageCreator")
  approvalDecisions ChecklistApproval[] @relation("ApprovalDecider")
  uploadedImages    ChecklistImage[]    @relation("ChecklistImageUploader")
}

model Role {
  id          String   @id @db.Char(24)
  role_name   String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  memberships ProjectMembership[]
}

model Project {
  id                     String    @id @db.Char(24)
  project_no             String?
  internal_order_no      String?
  project_name           String
  description            String?   @db.Text
  status                 String    @default("pending") // "pending" | "in_progress" | "completed"
  priority               String    @default("medium") // "low" | "medium" | "high"
  start_date             DateTime
  end_date               DateTime?
  templateName           String?
  isReviewApplicable     String? // "yes" | "no" | null
  reviewApplicableRemark String?   @db.Text
  overallDefectRate      Float?
  created_by             String    @db.Char(24)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  // Relations
  creator           User                @relation("UserProjects", fields: [created_by], references: [id])
  stages            Stage[]
  memberships       ProjectMembership[]
  approvals         ChecklistApproval[]
  projectChecklists ProjectChecklist[]
}

model ProjectMembership {
  id         Int      @id @default(autoincrement())
  project_id String   @db.Char(24)
  user_id    String   @db.Char(24)
  role_id    String   @db.Char(24)
  createdAt  DateTime @default(now())

  // Relations
  project Project @relation(fields: [project_id], references: [id])
  user    User    @relation(fields: [user_id], references: [id])
  role    Role    @relation(fields: [role_id], references: [id])

  @@unique([project_id, user_id, role_id])
  @@index([project_id])
  @@index([user_id])
}

model Stage {
  id             String   @id @db.Char(24)
  project_id     String   @db.Char(24)
  stage_name     String
  stage_key      String?
  description    String?  @db.Text
  status         String   @default("pending") // "pending" | "in_progress" | "completed"
  created_by     String?  @db.Char(24)
  loopback_count Int      @default(0)
  conflict_count Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  project           Project            @relation(fields: [project_id], references: [id])
  creator           User?              @relation("StageCreator", fields: [created_by], references: [id])
  projectChecklists ProjectChecklist[]

  @@index([project_id])
  @@index([project_id, stage_key])
}

model ChecklistApproval {
  id                    String    @id @db.Char(24)
  project_id            String    @db.Char(24)
  phase                 Int
  status                String    @default("pending") // "pending" | "approved" | "reverted" | "reverted_to_executor"
  requested_at          DateTime  @default(now())
  decided_at            DateTime?
  decided_by            String?   @db.Char(24)
  notes                 String?   @db.Text
  revertCount           Int       @default(0)
  executor_submitted    Boolean   @default(false)
  executor_submitted_at DateTime?
  reviewer_submitted    Boolean   @default(false)
  reviewer_submitted_at DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Relations
  project Project @relation(fields: [project_id], references: [id])
  decider User?   @relation("ApprovalDecider", fields: [decided_by], references: [id])

  @@unique([project_id, phase])
  @@index([project_id, phase])
}

model Template {
  id                   String   @id @db.Char(24)
  templateName         String?  @unique
  name                 String   @default("Default Quality Review Template")
  description          String?  @db.Text
  isActive             Boolean  @default(true)
  stageNames           Json?
  defectCategories     Json?
  defectCategoryGroups Json?
  stageData            Json?
  modifiedBy           String?  @db.Char(24)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model ProjectChecklist {
  id               String   @id @db.Char(24)
  projectId        String   @db.Char(24)
  stageId          String   @db.Char(24)
  stage            String
  groups           Json?
  iterations       Json?
  currentIteration Int      @default(1)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  project  Project @relation(fields: [projectId], references: [id])
  stageRef Stage   @relation(fields: [stageId], references: [id])

  @@unique([projectId, stageId])
  @@index([projectId])
  @@index([stageId])
}

model ChecklistImage {
  id            String   @id @db.Char(24)
  project_id    String?  @db.Char(24)
  checklist_id  String?  @db.Char(24)
  defect_id     String?  @db.VarChar(255)
  question_id   String   @db.VarChar(255)
  image_path    String   @db.Text
  uploaded_by   String?  @db.Char(24)
  role          String?  @db.VarChar(50)
  original_name String?  @db.VarChar(255)
  mime_type     String?  @db.VarChar(100)
  size_bytes    Int?
  created_at    DateTime @default(now())

  // Relations
  uploader User? @relation("ChecklistImageUploader", fields: [uploaded_by], references: [id])

  @@index([question_id])
  @@index([uploaded_by])
  @@index([project_id])
  @@index([checklist_id])
  @@index([defect_id])
}

model GlobalDefectCategory {
  id        String   @id @db.Char(24)
  name      String
  group     String   @default("General")
  keywords  Json? // Array of strings
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GlobalDefectCategorySettings {
  id                   String   @id @db.Char(24)
  defectCategoryGroups Json? // Array of strings
  updatedAt            DateTime @updatedAt
}
